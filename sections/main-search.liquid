<section class="section simple-page">
  <div class="section-header">
    <h2>Search</h2>
    <p>Search results for “{{ search.terms }}”</p>
  </div>

  <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products" />
    <button class="btn primary" type="submit">Search</button>
  </form>

  {% if search.performed %}
    <div class="product-grid" style="margin-top:24px;">
      {% for item in search.results %}
        {% if item.object_type == 'product' %}
          <article class="product-card">
            <div class="product-image">
              {% if item.featured_image %}
                <img src="{{ item.featured_image | image_url: width: 900 }}" alt="{{ item.title }}">
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
            <div class="product-info">
              <h3>{{ item.title }}</h3>
              <div class="price-row">
                <span>{{ item.price | money }}</span>
              </div>
              <a class="btn primary" href="{{ item.url }}">View</a>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Main search",
  "settings": []
}
{% endschema %}
