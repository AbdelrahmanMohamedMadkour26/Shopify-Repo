<section class="section why">
  <div class="section-header">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subtext }}</p>
  </div>
  <div class="why-grid">
    {% for block in section.blocks %}
      <div class="why-card" {{ block.shopify_attributes }}>
        <i class="ph {{ block.settings.icon_class }}"></i>
        <h3>{{ block.settings.title }}</h3>
        <p>{{ block.settings.text }}</p>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Why choose us",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Choose Keyyef"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Every detail crafted for calm, confidence, and consistency."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "icon_class",
          "label": "Icon class",
          "default": "ph-seal-check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Premium Quality"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "High-grade steel, ceramic, and precision components."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why choose us",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon_class": "ph-seal-check",
            "title": "Premium Quality",
            "text": "High-grade steel, ceramic, and precision components."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_class": "ph-truck",
            "title": "Fast Delivery",
            "text": "Same-day processing with careful packaging."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_class": "ph-heart",
            "title": "Trusted by Coffee Lovers",
            "text": "Thousands of five-star rituals worldwide."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_class": "ph-shield-check",
            "title": "Easy Returns",
            "text": "Hassle-free returns within 30 days."
          }
        }
      ]
    }
  ]
}
{% endschema %}
