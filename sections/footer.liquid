<footer class="footer">
  <div class="footer-grid">
    <div>
      <h3>{{ section.settings.logo_text }}</h3>
      <p>{{ section.settings.description }}</p>
    </div>
    <div>
      <h4>Quick Links</h4>
      {% if section.settings.menu != blank %}
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="#home">Home</a>
        <a href="#shop">Shop</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
      {% endif %}
    </div>
    <div>
      <h4>Connect</h4>
      <div class="socials">
        {% if section.settings.instagram_url != blank %}
          <a aria-label="Instagram" href="{{ section.settings.instagram_url }}"><i class="ph ph-instagram-logo"></i></a>
        {% endif %}
        {% if section.settings.facebook_url != blank %}
          <a aria-label="Facebook" href="{{ section.settings.facebook_url }}"><i class="ph ph-facebook-logo"></i></a>
        {% endif %}
        {% if section.settings.twitter_url != blank %}
          <a aria-label="Twitter" href="{{ section.settings.twitter_url }}"><i class="ph ph-twitter-logo"></i></a>
        {% endif %}
      </div>
    </div>
    <div>
      <h4>Newsletter</h4>
      <p>{{ section.settings.newsletter_text }}</p>
      {% form 'customer' %}
        <div class="newsletter">
          <input type="email" name="contact[email]" placeholder="Email address" required>
          <button class="btn primary" type="submit">Join</button>
        </div>
      {% endform %}
    </div>
  </div>
  <div class="footer-bottom">
    <span>© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Keyyef"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Luxury coffee machines and tools curated for a calm, rich, and refined coffee experience."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "Be the first to hear about new releases."
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter URL"
    }
  ]
}
{% endschema %}
