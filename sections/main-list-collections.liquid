<section class="section simple-page">
  <div class="section-header">
    <h2>Collections</h2>
    <p>Browse all collections.</p>
  </div>
  <div class="category-grid">
    {% for collection in collections %}
      <article class="category-card">
        <div class="product-image" style="height:160px; border-radius:16px; overflow:hidden;">
          {% if collection.image %}
            <img src="{{ collection.image | image_url: width: 900 }}" alt="{{ collection.title }}">
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
        <h3>{{ collection.title }}</h3>
        <p>{{ collection.products_count }} products</p>
        <a href="{{ collection.url }}">View Collection</a>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "List collections",
  "settings": []
}
{% endschema %}
