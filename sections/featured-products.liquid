<section class="section products" id="shop">
  <div class="section-header">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subtext }}</p>
  </div>
  <div class="product-grid">
    {% if section.settings.collection != blank and section.settings.collection.products_count > 0 %}
      {% for product in section.settings.collection.products limit: section.settings.product_limit %}
        <article class="product-card">
          <div class="product-image">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.title }}">
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <div class="product-info">
            <h3>{{ product.title }}</h3>
            <div class="price-row">
              <span>{{ product.price | money }}</span>
              <div class="rating">
                <i class="ph ph-star-fill"></i>
                <i class="ph ph-star-fill"></i>
                <i class="ph ph-star-fill"></i>
                <i class="ph ph-star-fill"></i>
                <i class="ph ph-star-half"></i>
                <small>{{ section.settings.default_rating }}</small>
              </div>
            </div>
            {% form 'product', product %}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button class="btn primary" type="submit">Add to Cart</button>
            {% endform %}
          </div>
        </article>
      {% endfor %}
    {% else %}
      {% for i in (1..4) %}
        <article class="product-card">
          <div class="product-image">
            {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
          <div class="product-info">
            <h3>Signature Brew Kit {{ i }}</h3>
            <div class="price-row">
              <span>$149</span>
              <div class="rating">
                <i class="ph ph-star-fill"></i>
                <i class="ph ph-star-fill"></i>
                <i class="ph ph-star-fill"></i>
                <i class="ph ph-star-fill"></i>
                <i class="ph ph-star-half"></i>
                <small>{{ section.settings.default_rating }}</small>
              </div>
            </div>
            <button class="btn primary" type="button">Add to Cart</button>
          </div>
        </article>
      {% endfor %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "High-performance machines and luxurious essentials."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Products to show",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "default_rating",
      "label": "Default rating",
      "default": "4.8"
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
