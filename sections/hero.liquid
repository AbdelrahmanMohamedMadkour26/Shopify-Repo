{% assign hero_bg = section.settings.background_image %}
<section class="hero" id="home" {% if hero_bg %}style="background-image: url('{{ hero_bg | image_url: width: 2000 }}');"{% endif %}>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <p class="subtext">{{ section.settings.subtext }}</p>
    <div class="hero-cta">
      <a class="btn primary" href="{{ section.settings.primary_cta_link }}">{{ section.settings.primary_cta_label }}</a>
      <a class="btn ghost" href="{{ section.settings.secondary_cta_link }}">{{ section.settings.secondary_cta_label }}</a>
    </div>
    <div class="hero-stats">
      <div>
        <span>{{ section.settings.stat_1_value }}</span>
        <small>{{ section.settings.stat_1_label }}</small>
      </div>
      <div>
        <span>{{ section.settings.stat_2_value }}</span>
        <small>{{ section.settings.stat_2_label }}</small>
      </div>
      <div>
        <span>{{ section.settings.stat_3_value }}</span>
        <small>{{ section.settings.stat_3_label }}</small>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Premium Coffee Lifestyle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elevate Your Coffee Experience"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Premium coffee machines & tools for true coffee lovers"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary CTA label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Primary CTA link",
      "default": "#shop"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary CTA label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary CTA link",
      "default": "#categories"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 value",
      "default": "120+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Curated machines"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stat 2 value",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "Average rating"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Stat 3 value",
      "default": "24h"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Fast dispatch"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
