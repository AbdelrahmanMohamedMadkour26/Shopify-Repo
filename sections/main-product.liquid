<section class="section simple-page">
  <div class="product-detail">
    <div class="product-gallery">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | image_url: width: 1100 }}" alt="{{ product.title }}">
      {% endif %}
    </div>
    <div class="product-summary">
      <h2>{{ product.title }}</h2>
      <div class="price-row">
        <span>{{ product.price | money }}</span>
      </div>
      {% if product.description != blank %}
        <div class="page-content">{{ product.description }}</div>
      {% endif %}
      {% form 'product', product %}
        {% if product.variants.size > 1 %}
          <label>
            Variant
            <select name="id">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                  {{ variant.title }} - {{ variant.price | money }}
                </option>
              {% endfor %}
            </select>
          </label>
        {% else %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {% endif %}
        <button class="btn primary" type="submit">Add to Cart</button>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
