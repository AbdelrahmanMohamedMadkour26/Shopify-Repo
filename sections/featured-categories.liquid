<section class="section" id="categories">
  <div class="section-header">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subtext }}</p>
  </div>
  <div class="category-grid">
    {% for block in section.blocks %}
      <article class="category-card" {{ block.shopify_attributes }}>
        <div class="icon-badge"><i class="ph {{ block.settings.icon_class }}"></i></div>
        <h3>{{ block.settings.title }}</h3>
        <p>{{ block.settings.description }}</p>
        <a href="{{ block.settings.link }}">{{ block.settings.link_label }}</a>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Featured categories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Categories"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Crafted essentials for every brewing ritual."
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "icon_class",
          "label": "Icon class",
          "default": "ph-coffee"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Coffee Machines"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Smart, silent, and beautifully engineered."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Shop Machines"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "default": "#shop"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured categories",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "icon_class": "ph-coffee",
            "title": "Coffee Machines",
            "description": "Smart, silent, and beautifully engineered.",
            "link_label": "Shop Machines",
            "link": "#shop"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon_class": "ph-funnel-simple",
            "title": "Grinders",
            "description": "Precision grinding for consistent flavor.",
            "link_label": "Shop Grinders",
            "link": "#shop"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon_class": "ph-drop",
            "title": "أدوات تحضير القهوة",
            "description": "Brewing tools for pour-over perfection.",
            "link_label": "Explore Tools",
            "link": "#shop"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon_class": "ph-circles-three",
            "title": "Accessories",
            "description": "Every detail, elevated for the ritual.",
            "link_label": "Browse Accessories",
            "link": "#shop"
          }
        }
      ]
    }
  ]
}
{% endschema %}
