<section class="section about" id="about">
  <div class="about-text">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.body }}</p>
    <div class="about-list">
      {% for block in section.blocks %}
        <div {{ block.shopify_attributes }}>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
    <a class="btn ghost" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
  </div>
  <div class="about-image">
    {% if section.settings.image %}
      <img src="{{ section.settings.image | image_url: width: 1000 }}" alt="{{ section.settings.image.alt | escape }}">
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "About",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Keyyef is crafted for those who truly appreciate coffee…"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "We blend timeless café culture with modern performance. Every machine, tool, and accessory is curated to deliver an elevated ritual — from the aroma to the last sip."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Talk to our experts"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link",
      "default": "#contact"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Curated by baristas"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Each product is tested for texture, temperature, and taste."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About",
      "blocks": [
        {
          "type": "highlight",
          "settings": {
            "title": "Curated by baristas",
            "text": "Each product is tested for texture, temperature, and taste."
          }
        },
        {
          "type": "highlight",
          "settings": {
            "title": "Design-led selection",
            "text": "Minimal lines, premium materials, and a cozy glow."
          }
        }
      ]
    }
  ]
}
{% endschema %}
