<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ page_title }}{% if current_tags %} – {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} – Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}</title>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css">
  <style>
    :root {
      --brown: {{ settings.color_brown | default: '#3e2723' }};
      --beige: {{ settings.color_beige | default: '#f5f5dc' }};
      --black: {{ settings.color_black | default: '#0f0f0f' }};
      --gold: {{ settings.color_gold | default: '#c5a25b' }};
      --caramel: {{ settings.color_caramel | default: '#b98b5a' }};
    }
  </style>
  {{ 'styles.css' | asset_url | stylesheet_tag }}
</head>
<body>
  <div class="page">
    {% section 'header' %}
    <main id="top">
      {{ content_for_layout }}
    </main>
    {% section 'footer' %}
  </div>

  <script src="{{ 'script.js' | asset_url }}" defer></script>
</body>
</html>
