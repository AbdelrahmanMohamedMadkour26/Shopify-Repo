<section class="section simple-page">
  <div class="section-header">
    <h2>Your Cart</h2>
    <p>Review your selected items.</p>
  </div>

  {% if cart.item_count == 0 %}
    <p>Your cart is empty.</p>
    <a class="btn primary" href="{{ routes.all_products_collection_url }}">Browse products</a>
  {% else %}
    <div class="cart-list">
      {% for item in cart.items %}
        <div class="cart-item">
          <div class="cart-thumb">
            <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.product.title }}">
          </div>
          <div class="cart-info">
            <h4>{{ item.product.title }}</h4>
            <p>{{ item.variant.title }}</p>
            <span>{{ item.price | money }}</span>
          </div>
          <div class="cart-qty">
            <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" form="cart" />
          </div>
        </div>
      {% endfor %}
    </div>
    <form action="{{ routes.cart_url }}" method="post" id="cart">
      <button class="btn primary" type="submit" name="checkout">Checkout</button>
    </form>
  {% endif %}
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": []
}
{% endschema %}
