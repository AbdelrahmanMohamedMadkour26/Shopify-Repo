<section class="section simple-page">
  <div class="section-header">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>
  </div>
  <a class="btn primary" href="{{ routes.root_url }}">Back to home</a>
</section>

{% schema %}
{
  "name": "404",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page not found"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "The page you are looking for doesn’t exist."
    }
  ]
}
{% endschema %}
